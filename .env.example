GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json
BOT_GOOGLE_ACCOUNT_EMAIL=bot@gmail.com
BOT_GOOGLE_ACCOUNT_PASSWORD=yourpassword
BOT_DISPLAY_NAME=MeetRead AI
MEETINGS_OUTPUT_DIR=./meetings
POLL_INTERVAL_SECONDS=300
MAX_MEETING_DURATION_HOURS=3
JOIN_BUFFER_MINUTES=2
LOBBY_WAIT_MINUTES=10
SAVE_MP3=true
DELETE_CHUNKS_AFTER_CONCAT=true
AUDIO_BACKEND=auto
AUDIO_SAMPLERATE=44100
AUDIO_CHANNELS=2
AUDIO_CHUNK_SECONDS=60
# Optional: set this if undetected-chromedriver chooses the wrong major version.
# Your log showed Chrome 148, so use CHROME_VERSION_MAIN=148 for that install.
# CHROME_VERSION_MAIN=148
# CHROME_BINARY_PATH=/usr/bin/google-chrome
# CHROME_HEADLESS=false
# Optional: sign in once manually with this dedicated profile, then reuse it.
# CHROME_USER_DATA_DIR=./chrome-bot-profile
# CHROME_PROFILE_DIRECTORY=Default
# SKIP_GOOGLE_LOGIN=true
