GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json
BOT_GOOGLE_ACCOUNT_EMAIL=bot@gmail.com
BOT_GOOGLE_ACCOUNT_PASSWORD=yourpassword
BOT_DISPLAY_NAME=MeetRead AI
MEETINGS_OUTPUT_DIR=./meetings
POLL_INTERVAL_SECONDS=300
MAX_MEETING_DURATION_HOURS=3
JOIN_BUFFER_MINUTES=2
LOBBY_WAIT_MINUTES=10
SAVE_MP3=true
DELETE_CHUNKS_AFTER_CONCAT=true
MEETING_INTELLIGENCE_ENABLED=true
MEETING_INTELLIGENCE_PROVIDER=rule_based
# Optional LLM intelligence. Set MEETING_INTELLIGENCE_PROVIDER=llm to enable.
MEETING_LLM_PROVIDER=openai_compatible
MEETING_LLM_BASE_URL=http://localhost:11434/v1
MEETING_LLM_MODEL=llama3.1
MEETING_LLM_API_KEY=
MEETING_LLM_TEMPERATURE=0.2
MEETING_LLM_TIMEOUT_SECONDS=120
MEETING_LLM_MAX_INPUT_CHARS=60000
MEETING_LLM_RESPONSE_FORMAT=json_schema
# Optional: reasoning_effort for providers that support it (e.g. sarvam: low, medium, high).
# MEETING_LLM_REASONING_EFFORT=
MEETING_LLM_FALLBACK_PROVIDER=rule_based
# Sarvam AI example (https://api.sarvam.ai):
# MEETING_LLM_PROVIDER=sarvam
# MEETING_LLM_BASE_URL=https://api.sarvam.ai/v1
# MEETING_LLM_MODEL=sarvam-105b
# MEETING_LLM_API_KEY=your-sarvam-api-key
# MEETING_LLM_RESPONSE_FORMAT=json_object
# MEETING_LLM_REASONING_EFFORT=high
SUMMARY_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SUMMARY_RECIPIENTS=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=30
SMTP_SUBJECT_PREFIX=[MeetRead]
AUDIO_BACKEND=auto
AUDIO_SAMPLERATE=44100
AUDIO_CHANNELS=2
AUDIO_CHUNK_SECONDS=60
# Optional: set this if undetected-chromedriver chooses the wrong major version.
# Your log showed Chrome 148, so use CHROME_VERSION_MAIN=148 for that install.
# CHROME_VERSION_MAIN=148
# CHROME_BINARY_PATH=/usr/bin/google-chrome
# CHROME_HEADLESS=false
# Optional: sign in once manually with this dedicated profile, then reuse it.
# CHROME_USER_DATA_DIR=./chrome-bot-profile
# CHROME_PROFILE_DIRECTORY=Default
# SKIP_GOOGLE_LOGIN=true
